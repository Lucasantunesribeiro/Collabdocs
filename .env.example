NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# .NET API — Document Management Context (CRUD, business rules, audit logging)
# Used server-side only (Next.js proxy route /api/dotnet/[...path]) — not NEXT_PUBLIC.
# In Vercel: set this to your AWS ALB DNS, e.g. http://your-alb.us-east-1.elb.amazonaws.com/api
DOTNET_API_URL=http://localhost:5000/api

# Cloudflare Worker — Real-Time Collaboration Context (WebSocket, presence, edge rate limiting)
NEXT_PUBLIC_API_URL=http://localhost:8787/api
NEXT_PUBLIC_WS_URL=wss://collab-docs.collabdocs.workers.dev

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_ORIGINS=http://localhost:3000
